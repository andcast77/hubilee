# =
# Hubilee — Docker Compose Environment Variables
# Copy this file to .env and adjust values for your environment.
# =

# --- Stack ---
STACK_NAME=
NETWORK_NAME=

# --- Postgres (Docker Compose) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=
# From host (pnpm dev, Prisma Studio, migrate:dev)
DATABASE_URL=
DATABASE_URL_DEV=

# --- API ---
JWT_SECRET=
FIELD_ENCRYPTION_KEY=
CORS_ORIGIN=

# --- Next.js apps ---
# NEXT_PUBLIC_* values are inlined at Docker build time (see docker-compose build args).
NEXT_PUBLIC_API_URL=
API_INTERNAL_URL=
NODE_ENV=

# Public URLs per app (these must be reachable from the browser)
HUB_URL=
POS_URL=
HR_URL=
TECH_URL=

# Caddy domains
API_DOMAIN=
HUB_DOMAIN=
HR_DOMAIN=
POS_DOMAIN=
TECH_DOMAIN=

# Webhook
UPDATE_DOMAIN=
