# =============================================================================
# Hubilee — Docker Compose Environment Variables
# Copy this file to .env and adjust values for your environment.
# =============================================================================

# --- Stack ---
STACK_NAME=hubilee
NETWORK_NAME=hubilee-caddy-network

# --- Postgres (Docker Compose) ---
POSTGRES_USER=hubilee
POSTGRES_PASSWORD=hubilee
POSTGRES_DB=hubilee
POSTGRES_PORT=5432
# From host (pnpm dev, Prisma Studio, migrate:dev)
DATABASE_URL=postgresql://hubilee:hubilee@localhost:5432/hubilee
DATABASE_URL_DEV=postgresql://hubilee:hubilee@localhost:5432/hubilee
# API container uses postgresql://...@postgres:5432/... (see docker-compose.yml)

# --- API ---
JWT_SECRET=change-me-to-a-random-secret
FIELD_ENCRYPTION_KEY=change-me-to-a-32-char-base64-key
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:3006

# --- Next.js apps ---
# NEXT_PUBLIC_* values are inlined at Docker build time (see docker-compose build args).
NEXT_PUBLIC_API_URL=http://localhost:3000
API_INTERNAL_URL=http://api:3000
NODE_ENV=production

# Public URLs per app (these must be reachable from the browser)
HUB_URL=http://localhost:3001
POS_URL=http://localhost:3002
HR_URL=http://localhost:3003
TECH_URL=http://localhost:3004

# Caddy domains (override in production .env)
API_DOMAIN=api.hubilee.app
HUB_DOMAIN=hub.hubilee.app
HR_DOMAIN=rrhh.hubilee.app
POS_DOMAIN=pos.hubilee.app
TECH_DOMAIN=tech.hubilee.app

# Webhook
UPDATE_DOMAIN=update.hubilee.app
