# Docker Compose / host tooling only.
# Apps (local + Vercel): apps/{api,hub,pos,hr,tech}/.env.example
# Copy: cp .env.example .env

STACK_NAME=
NETWORK_NAME=

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# Host tooling (migrate / Prisma Studio). Compose API uses postgres hostname, not these.
DATABASE_URL=
DATABASE_URL_DEV=

NEXT_PUBLIC_API_URL=
API_INTERNAL_URL=
NODE_ENV=

# Browser-reachable app URLs (Compose build args → NEXT_PUBLIC_*).
HUB_URL=
POS_URL=
HR_URL=
TECH_URL=

API_DOMAIN=
HUB_DOMAIN=
HR_DOMAIN=
POS_DOMAIN=
TECH_DOMAIN=
UPDATE_DOMAIN=
