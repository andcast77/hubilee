{
  "name": "hubilee",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@hubilee/api...",
    "dev:hub": "turbo run dev --filter=@hubilee/hub...",
    "dev:pos": "turbo run dev --filter=@hubilee/pos...",
    "dev:tech": "turbo run dev --filter=@hubilee/tech...",
    "dev:hr": "turbo run dev --filter=@hubilee/hr...",
    "dev:ui": "turbo run dev --filter=@hubilee/ui...",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@hubilee/api...",
    "build:hub": "turbo run build --filter=@hubilee/hub...",
    "build:pos": "turbo run build --filter=@hubilee/pos...",
    "build:tech": "turbo run build --filter=@hubilee/tech...",
    "build:hr": "turbo run build --filter=@hubilee/hr...",
    "build:contracts": "turbo run build --filter=@hubilee/contracts...",
    "build:database": "turbo run build --filter=@hubilee/database...",
    "build:ui": "turbo run build --filter=@hubilee/ui...",
    "knip:hub": "pnpm -C apps/hub exec knip --config knip.jsonc --production --include files",
    "knip:pos": "pnpm -C apps/pos exec knip --config knip.jsonc --production --include files",
    "knip:tech": "pnpm -C apps/tech exec knip --config knip.jsonc --production --include files",
    "knip:hr": "pnpm -C apps/hr exec knip --config knip.jsonc --production --include files",
    "knip:all": "pnpm run knip:hub && pnpm run knip:pos && pnpm run knip:tech && pnpm run knip:hr",
    "migrate:dev": "pnpm --filter=@hubilee/database run migrate:dev",
    "migrate:deploy": "pnpm --filter=@hubilee/database run migrate:deploy",
    "db:push": "pnpm --filter=@hubilee/database run db:push",
    "db:push:dev": "pnpm --filter=@hubilee/database run db:push:dev",
    "db:seed": "pnpm --filter=@hubilee/database run db:seed",
    "db:seed:dev": "pnpm --filter=@hubilee/database run db:seed:dev",
    "db:reset": "pnpm --filter=@hubilee/database run db:reset",
    "db:reset:dev": "pnpm --filter=@hubilee/database run db:reset:dev",
    "studio": "pnpm --filter=@hubilee/database run studio",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck --continue",
    "test": "turbo run test",
    "verify:plan39": "pnpm --filter @hubilee/api exec vitest run src/__tests__/unit/registration-otp.service.test.ts src/__tests__/unit/registration-ticket.service.test.ts"
  },
  "devDependencies": {
    "knip": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
