# Caddy reverse proxy — hubilee stack domain routing
# TLS is automatic via Let's Encrypt (Caddy default).
# Usage: docker compose up -d

{$API_DOMAIN:api.hubilee.app} {
    reverse_proxy api:3000
}

{$HR_DOMAIN:rrhh.hubilee.app} {
    reverse_proxy hr:3003
}

{$POS_DOMAIN:pos.hubilee.app} {
    reverse_proxy pos:3002
}

{$HUB_DOMAIN:hub.hubilee.app} {
    reverse_proxy hub:3001
}

{$TECH_DOMAIN:tech.hubilee.app} {
    reverse_proxy tech:3004
}

{$UPDATE_DOMAIN:update.hubilee.app} {
    reverse_proxy 172.18.0.1:2999
}
