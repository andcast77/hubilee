# Baro environment variables (copy to .env and fill in values)
# cp apps/baro/.env.example apps/baro/.env

# Database
DATABASE_URL="postgresql://baro:baro@localhost:5433/baro"
DIRECT_URL="postgresql://baro:baro@localhost:5433/baro"

# JWT
JWT_ACCESS_SECRET=change-me-to-a-random-secret

# Next.js
NEXT_PUBLIC_EXPEDIENTE_OUTPUT_SCOPE=sanjuan

# Auth
AUTH_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
AUTH_ALLOWED_ORIGINS=http://localhost:3000

# Server Actions
SERVER_ACTIONS_ALLOWED_ORIGINS=http://localhost:3000

# Preview
EXPEDIENTE_PREVIEW_ETAG_REVISION=1
