{
  "name": "@hubilee/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "NODE_ENV=production node dist/server.js",
    "test": "NODE_ENV=test vitest run",
    "test:unit": "NODE_ENV=test vitest run src/__tests__/unit",
    "test:integration": "NODE_ENV=test vitest run src/__tests__/integration",
    "test:watch": "NODE_ENV=test vitest",
    "test:ui": "NODE_ENV=test vitest --ui",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "test:endpoints": "node scripts/test-endpoints.js",
    "load:smoke": "node scripts/load-smoke.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "DB_TARGET=dev prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:push:dev": "DB_TARGET=dev prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:dev": "DB_TARGET=dev tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:reset:dev": "DB_TARGET=dev prisma migrate reset --force",
    "db:studio": "prisma studio",
    "studio": "prisma studio",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:dev": "DB_TARGET=dev prisma migrate dev"
  },
  "dependencies": {
    "@fastify/cookie": "catalog:",
    "@fastify/cors": "catalog:",
    "@fastify/env": "catalog:",
    "@fastify/rate-limit": "catalog:",
    "@hubilee/contracts": "workspace:*",
    "@neondatabase/serverless": "catalog:",
    "@prisma/adapter-neon": "catalog:",
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "@upstash/redis": "catalog:",
    "bcryptjs": "catalog:",
    "dotenv": "catalog:",
    "fastify": "catalog:",
    "fastify-plugin": "catalog:",
    "jsonwebtoken": "catalog:",
    "node-cron": "catalog:",
    "otplib": "catalog:",
    "pg": "catalog:",
    "qrcode": "catalog:",
    "resend": "catalog:",
    "web-push": "catalog:",
    "ws": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@fastify/swagger": "catalog:",
    "@fastify/swagger-ui": "catalog:",
    "@types/bcryptjs": "catalog:",
    "@types/jsonwebtoken": "catalog:",
    "@types/node": "catalog:",
    "@types/node-cron": "catalog:",
    "@types/qrcode": "catalog:",
    "@types/web-push": "catalog:",
    "@types/ws": "catalog:",
    "autocannon": "catalog:",
    "cross-env": "catalog:",
    "esbuild": "catalog:",
    "prisma": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
