{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "cd ../.. && pnpm exec turbo run build --filter=@hubilee/contracts... && pnpm --filter @hubilee/api run build:vercel",
  "installCommand": "cd ../.. && pnpm install",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "{dist/vercel-server.js,dist/vercel-server.js.map,src/generated/prisma/**}"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/:path*",
      "destination": "/api"
    }
  ],
  "crons": [
    {
      "path": "/v1/internal/cron/inventory-alert",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/v1/internal/cron/scheduled-report-daily",
      "schedule": "59 23 * * *"
    },
    {
      "path": "/v1/internal/cron/scheduled-report-weekly",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/v1/internal/cron/invoice-reminder",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/v1/internal/cron/backup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/v1/internal/cron/tech-reminder",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/v1/internal/cron/data-retention",
      "schedule": "0 3 * * *"
    }
  ]
}
