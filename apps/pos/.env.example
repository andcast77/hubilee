# Pos (Next.js)
# Copy this file to apps/pos/.env.local and adjust values per environment.

# Do not set NODE_ENV here or in Vercel for this app. Next.js requires it to be
# development | production | test; use VERCEL_ENV (Vercel) or a custom var like
# NEXT_PUBLIC_APP_ENV if you need staging/preview semantics.

# Base URL of the central API consumed by Pos.
NEXT_PUBLIC_API_URL=<API_BASE_URL>

# Google OAuth (API-owned): Pos origin must be listed in API CORS_ORIGIN
# so returnOrigin allowlisting accepts this app (e.g. http://localhost:3002).

# Cloudflare Turnstile site key (public). Dev: dummy “always passes” — https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Hub base URL (links when Pos is inactive or for owner actions). Dev default: http://localhost:3001
NEXT_PUBLIC_HUB_URL=<HUB_APP_URL>

# Optional public VAPID key for browser push notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<VAPID_PUBLIC_KEY>

# Note: server-only vars (VAPID private keys, DB URLs, JWT) must live in backend/API, not Pos frontend.

# Public URLs of sibling apps (landing module cards / footer). Dev defaults: Hub 3001, Pos 3002, HR 3003, Tech 3004.
NEXT_PUBLIC_POS_URL=<POS_APP_URL>
NEXT_PUBLIC_HR_URL=<HR_APP_URL>
NEXT_PUBLIC_TECH_URL=<TECH_APP_URL>
